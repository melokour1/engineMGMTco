{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/strategy", "destination": "/strategy.html" },
    { "source": "/tips",     "destination": "/tips.html"     },
    { "source": "/watch",    "destination": "/watch.html"    },
    { "source": "/terms",    "destination": "/terms.html"    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/404",          "dest": "/404.html"           },
    { "src": "/(.*)",         "dest": "/404.html", "status": 404 }
  ]
}
